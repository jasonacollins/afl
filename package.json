{
  "name": "afl-predictions",
  "version": "1.0.0",
  "description": "AFL Predictions App",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "import": "node scripts/automation/import-data.js",
    "sync-games": "node scripts/automation/sync-games.js",
    "daily-sync": "node scripts/automation/daily-sync.js",
    "db-maintenance": "node scripts/automation/db-maintenance.js",
    "test": "npm run test:js:coverage && npm run test:python",
    "test:js": "jest --runInBand",
    "test:js:coverage": "jest --runInBand --coverage",
    "test:python": "python3 scripts/tests/run_pytest_with_coverage.py",
    "test:watch": "npm run test:js -- --watch",
    "test:coverage": "npm run test:js:coverage && npm run test:python"
  },
  "engines": {
    "node": ">=18.14.0"
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "bcrypt": "^6.0.0",
    "connect-sqlite3": "^0.9.16",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.4.2",
    "ejs": "^6.0.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "method-override": "^3.0.0",
    "multer": "^2.2.0",
    "node-fetch": "^3.3.2",
    "sqlite3": "^5.1.7",
    "tar-fs": "^3.1.2",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "linkedom": "^0.18.12",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  },
  "overrides": {
    "@babel/core": "7.29.6",
    "@tootallnate/once": "3.0.1",
    "form-data": "4.0.6",
    "js-yaml": "3.15.0",
    "qs": "6.15.2",
    "tar": "7.5.16"
  }
}
