.DS_Store

# Season simulation outputs (runtime-generated, not source-controlled)
data/simulations/*.json

# Database files
data/*.db
data/*.db-shm
data/*.db-wal
data/database/*.db
data/database/*.db-shm
data/database/*.db-wal
data/database/backups/*.db

# Temporary data directories  
data/temp/
data/cache/
scripts/data/cache/

# Python cache files
scripts/__pycache__/
scripts/core/__pycache__/
scripts/**/__pycache__/
*.pyc
**/*.pyc

# Generated prediction files (typically regenerated daily)
data/predictions/**/*.csv
data/predictions/**/*.json

# Historical data files (large, frequently updated)
data/historical/

# ELO model optimization artifacts
*.png
data/models/**/optimization_*.json
data/models/**/test_*.json

# Training summaries and logs
data/training_summary.txt
data/**/*_summary.txt
