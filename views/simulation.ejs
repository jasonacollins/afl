<%- include('partials/header') %>

<div class="container simulation-page">
    <div class="simulation-header">
        <h1 id="simulation-title">Season Simulation</h1>
    </div>

    <div class="card simulation-card">
        <div class="card-header">
            <div class="card-title">Season Projection</div>
            <div class="controls">
                <div class="control-group">
                    <label for="year-select">Season</label>
                    <select id="year-select">
                        <option value="<%= selectedYear %>" selected><%= selectedYear %></option>
                    </select>
                </div>
            </div>
        </div>

        <div id="round-snapshot-nav" class="round-selector simulation-round-selector is-hidden">
            <h2>Before-Round Snapshots</h2>
            <div id="round-snapshot-context" class="simulation-round-context"></div>
            <div id="round-tabs" class="round-buttons simulation-round-buttons" role="tablist" aria-label="Simulation rounds">
                <!-- Round tabs populated by JavaScript -->
            </div>
        </div>

        <!-- Loading indicator -->
        <div id="loading-indicator" class="loading-indicator">
            <div class="spinner"></div>
            <p>Loading simulation data...</p>
        </div>

        <!-- Error message -->
        <div id="error-message" class="error-message is-hidden">
            <p id="error-text"></p>
        </div>

        <!-- Summary stats -->
        <div class="summary-stats is-hidden" id="summary-stats">
            <div class="stat-box">
                <div class="stat-label">Simulations Run</div>
                <div class="stat-value" id="num-simulations">-</div>
                <div class="stat-subtext">Based on current ELO ratings</div>
            </div>
            <div class="stat-box">
                <div class="stat-label">Completed Matches</div>
                <div class="stat-value" id="completed-matches">-</div>
                <div class="stat-subtext" id="completed-subtext">-</div>
            </div>
            <div class="stat-box">
                <div class="stat-label">Matches to Simulate</div>
                <div class="stat-value" id="remaining-matches">-</div>
                <div class="stat-subtext">Regular season + finals</div>
            </div>
        </div>

        <!-- Results table -->
        <div class="table-scroll-hint" aria-hidden="true">Swipe horizontally to view all columns.</div>
        <div class="table-container simulation-results-table-container is-hidden" id="table-container">
            <table id="simulation-table">
                <thead>
                    <tr>
                        <th class="sortable" data-sort="position">Pos</th>
                        <th class="sortable" data-sort="team">Team</th>
                        <th class="sortable" data-sort="elo">Current ELO</th>
                        <th class="sortable" data-sort="record">Record</th>
                        <th class="sortable" data-sort="projected-wins">Projected Wins</th>
                        <th
                            id="top10-header"
                            class="<%= Number(selectedYear) >= 2026 ? 'sortable probability-col' : 'sortable probability-col is-hidden' %>"
                            data-sort="top10"
                        >Top 10</th>
                        <th
                            id="wildcard-header"
                            class="<%= Number(selectedYear) >= 2026 ? 'sortable probability-col' : 'sortable probability-col is-hidden' %>"
                            data-sort="wildcard"
                        >Wildcard</th>
                        <th
                            id="top6-header"
                            class="<%= Number(selectedYear) >= 2026 ? 'sortable probability-col' : 'sortable probability-col is-hidden' %>"
                            data-sort="top6"
                        >Top 6</th>
                        <th
                            id="top8-header"
                            class="<%= Number(selectedYear) >= 2026 ? 'sortable probability-col is-hidden' : 'sortable probability-col' %>"
                            data-sort="top8"
                        >Top 8</th>
                        <th class="sortable probability-col" data-sort="top4">Top 4</th>
                        <th
                            id="finals-week-header"
                            class="<%= Number(selectedYear) >= 2026 ? 'sortable probability-col' : 'sortable probability-col is-hidden' %>"
                            data-sort="finals-week-2"
                        ><%= Number(selectedYear) >= 2026 ? 'Finals Week 2' : 'Finals Week 1' %></th>
                        <th class="sortable probability-col" data-sort="prelim">Prelim</th>
                        <th class="sortable probability-col" data-sort="grand-final">Grand Final</th>
                        <th class="sortable probability-col" data-sort="premiership">Premier</th>
                    </tr>
                </thead>
                <tbody id="simulation-tbody">
                    <!-- Table rows will be populated by JavaScript -->
                </tbody>
            </table>
        </div>

    </div>

    <div class="card ladder-card is-hidden" id="ladder-position-card">
        <div class="card-title">Ladder Position Probabilities</div>
        <div class="ladder-description">
            Probability (%) of each team finishing in each ladder position
        </div>
        <div class="table-scroll-hint" aria-hidden="true">Swipe horizontally to view all columns.</div>
        <div class="table-container">
            <table class="matrix-table" id="matrix-table">
                <thead>
                    <tr id="matrix-header">
                        <!-- Will be populated by JavaScript -->
                    </tr>
                </thead>
                <tbody id="matrix-tbody">
                    <!-- Will be populated by JavaScript -->
                </tbody>
            </table>
        </div>
    </div>

    <div class="card info-card">
        <div class="card-title">Understanding the Simulation</div>
        <div class="simulation-info-content">
            <p><strong>Methodology:</strong> Monte Carlo simulation using current ELO ratings and remaining fixture. Each simulation randomly determines game outcomes based on win probabilities derived from ELO ratings and home ground advantages.</p>
            <p><strong>Win Range:</strong> Shows 10th to 90th percentile outcomes from simulations, representing realistic season trajectories.</p>
            <p><strong>Finals Progression:</strong> Probabilities account for both qualifying for finals and the path through the finals series based on ladder position (top 4 advantage, etc.)</p>
            <p><strong>Updates:</strong> Simulation data is regenerated after each completed round with updated ELO ratings.</p>
        </div>
    </div>
</div>

<script src="/js/simulation.js"></script>

<%- include('partials/footer') %>
