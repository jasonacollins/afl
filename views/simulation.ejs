<%- include('partials/header') %>

<div class="container">
    <div class="simulation-header">
        <h1 id="simulation-title">Season Simulation</h1>
    </div>

    <div class="card simulation-card">
        <div class="card-header">
            <div class="card-title">Season Projection</div>
            <div class="controls">
                <div class="control-group">
                    <label for="year-select">Season</label>
                    <select id="year-select">
                        <option value="<%= selectedYear %>" selected><%= selectedYear %></option>
                    </select>
                </div>
            </div>
        </div>

        <div id="round-snapshot-nav" class="round-snapshot-nav" style="display: none;">
            <div class="round-snapshot-heading">
                <span class="round-snapshot-title">Before-Round Snapshots</span>
                <span id="round-snapshot-context" class="round-snapshot-context"></span>
            </div>
            <div id="round-tabs" class="round-tabs" role="tablist" aria-label="Simulation rounds">
                <!-- Round tabs populated by JavaScript -->
            </div>
        </div>

        <!-- Loading indicator -->
        <div id="loading-indicator" class="loading-indicator">
            <div class="spinner"></div>
            <p>Loading simulation data...</p>
        </div>

        <!-- Error message -->
        <div id="error-message" class="error-message" style="display: none;">
            <p id="error-text"></p>
        </div>

        <!-- Summary stats -->
        <div class="summary-stats" id="summary-stats" style="display: none;">
            <div class="stat-box">
                <div class="stat-label">Simulations Run</div>
                <div class="stat-value" id="num-simulations">-</div>
                <div class="stat-subtext">Based on current ELO ratings</div>
            </div>
            <div class="stat-box">
                <div class="stat-label">Completed Matches</div>
                <div class="stat-value" id="completed-matches">-</div>
                <div class="stat-subtext" id="completed-subtext">-</div>
            </div>
            <div class="stat-box">
                <div class="stat-label">Matches to Simulate</div>
                <div class="stat-value" id="remaining-matches">-</div>
                <div class="stat-subtext">Regular season + finals</div>
            </div>
            <div class="stat-box">
                <div class="stat-label">Last Updated</div>
                <div class="stat-value" id="last-updated">-</div>
                <div class="stat-subtext">Updates after each round</div>
            </div>
        </div>

        <!-- Results table -->
        <div class="table-container" id="table-container" style="display: none;">
            <table id="simulation-table">
                <thead>
                    <tr>
                        <th class="sortable" data-sort="position">Pos</th>
                        <th class="sortable" data-sort="team">Team</th>
                        <th class="sortable" data-sort="elo">Current ELO</th>
                        <th class="sortable" data-sort="record">Record</th>
                        <th class="sortable" data-sort="projected-wins">Projected Wins</th>
                        <th class="sortable" data-sort="finals">Finals</th>
                        <th class="sortable" data-sort="top4">Top 4</th>
                        <th class="sortable" data-sort="prelim">Prelim</th>
                        <th class="sortable" data-sort="grand-final">Grand Final</th>
                        <th class="sortable" data-sort="premiership">Premiership</th>
                    </tr>
                </thead>
                <tbody id="simulation-tbody">
                    <!-- Table rows will be populated by JavaScript -->
                </tbody>
            </table>
        </div>

    </div>

    <div class="card ladder-card" id="ladder-position-card" style="display: none;">
        <div class="card-title">Ladder Position Probabilities</div>
        <div style="font-size: 13px; color: var(--light-text); margin: 15px 0 20px;">
            Probability (%) of each team finishing in each ladder position
        </div>
        <div class="table-container">
            <table class="matrix-table" id="matrix-table">
                <thead>
                    <tr id="matrix-header">
                        <!-- Will be populated by JavaScript -->
                    </tr>
                </thead>
                <tbody id="matrix-tbody">
                    <!-- Will be populated by JavaScript -->
                </tbody>
            </table>
        </div>
    </div>

    <div class="card info-card">
        <div class="card-title">Understanding the Simulation</div>
        <div style="font-size: 14px; color: var(--light-text); margin-top: 15px;">
            <p style="margin-bottom: 12px;"><strong>Methodology:</strong> Monte Carlo simulation using current ELO ratings and remaining fixture. Each simulation randomly determines game outcomes based on win probabilities derived from ELO ratings and home ground advantages.</p>
            <p style="margin-bottom: 12px;"><strong>Win Range:</strong> Shows 10th to 90th percentile outcomes from simulations, representing realistic season trajectories.</p>
            <p style="margin-bottom: 12px;"><strong>Finals Progression:</strong> Probabilities account for both qualifying for finals and the path through the finals series based on ladder position (top 4 advantage, etc.)</p>
            <p style="margin-bottom: 12px;"><strong>Updates:</strong> Simulation data is regenerated after each completed round with updated ELO ratings.</p>
        </div>
    </div>
</div>

<script src="/js/simulation.js"></script>

<%- include('partials/footer') %>
