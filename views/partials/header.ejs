<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="csrf-token" content="<%= csrfToken %>">
  <title>AFL Predictions</title>
  <link rel="stylesheet" href="<%= assetPath('/css/styles.css') %>">
  <script src="<%= assetPath('/js/scoring-service.js') %>"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="<%= assetPath('/js/elo-chart.js') %>"></script>
</head>
<body>
  <header class="site-header">
    <div class="header-container">
      <div class="header-top-row">
        <div class="logo">
          <h1><a href="/">AFL Predictions</a></h1>
        </div>

        <button
          type="button"
          class="mobile-nav-toggle"
          aria-expanded="false"
          aria-controls="site-menu"
          aria-label="Toggle navigation menu"
        >
          <span class="mobile-nav-toggle-label">Menu</span>
        </button>
      </div>

      <div id="site-menu" class="site-menu">
        <nav class="main-nav" aria-label="Primary">
          <a href="/" class="main-nav-link <%= currentPath === '/' ? 'active' : '' %>">Model predictions</a>
          <a href="/elo" class="main-nav-link <%= currentPath === '/elo' ? 'active' : '' %>">ELO</a>
          <a href="/simulation" class="main-nav-link <%= currentPath === '/simulation' ? 'active' : '' %>">Simulation</a>
          <% if (locals.user) { %>
            <a href="/predictions" class="main-nav-link <%= currentPath === '/predictions' || currentPath.startsWith('/predictions/') ? 'active' : '' %>">Predictor page</a>
            <% if (locals.isAdmin) { %>
              <a href="/admin" class="main-nav-link <%= currentPath === '/admin' || currentPath.startsWith('/admin/') ? 'active' : '' %>">Admin panel</a>
            <% } %>
          <% } %>
        </nav>

        <% if (locals.user) { %>
          <div class="user-info">
            <span>Hi, <%= user.display_name %>!</span>
            <% if (locals.isAdmin) { %>
              <span class="admin-badge">Admin</span>
            <% } %>
            <form action="/logout" method="POST" class="logout-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" class="button logout-button">Logout</button>
            </form>
          </div>
        <% } else { %>
          <div class="user-info">
            <a href="/login" class="button primary-button">Login</a>
          </div>
        <% } %>
      </div>
    </div>
  </header>
  
  <main>
