<%- include('partials/header') %>

<div class="container stats-page">
  <div class="tab-navigation">
    <a href="/predictions" class="tab">Make Predictions</a>
    <a href="/matches/stats" class="tab active">View Statistics</a>
  </div>
  
  <div class="year-selector">
    <h2>Select Season</h2>
    <div class="year-buttons">
      <% years.forEach(yearObj => { %>
        <a 
          href="/matches/stats?year=<%= yearObj.year %>" 
          class="year-button <%= yearObj.year === selectedYear ? 'selected' : '' %>"
        >
          <%= yearObj.year %>
        </a>
      <% }) %>
    </div>
  </div>
  
  <div class="stats-container" data-year="<%= selectedYear %>" data-user-id="<%= currentUser.id %>">
    <div class="stats-card leaderboard">
      <h2 class="stats-heading">Predictor Leaderboard - <%= selectedYear %> Season</h2>
      
      <% if (locals.isAdmin) { %>
        <div class="admin-controls">
          <h3>Admin Controls</h3>
          <div class="exclude-controls">
            <span>Exclude from statistics (saves automatically):</span>
            <div class="predictor-checkboxes">
              <%
                // Show all predictors (including excluded ones) for admin controls
                const allPredictors = locals.allPredictors || predictorStats;
                allPredictors.forEach(stats => {
              %>
                <label class="checkbox-label">
                  <input type="checkbox" class="exclude-checkbox"
                         data-predictor-id="<%= stats.id %>"
                         <%= stats.stats_excluded ? 'checked' : '' %> />
                  <%= stats.display_name %>
                </label>
              <% }) %>
            </div>
          </div>
        </div>
      <% } %>
      
      <% if (predictorStats.length === 0 || predictorStats.every(stat => stat.totalPredictions === 0)) { %>
        <div class="no-stats">
          <p>No prediction results available.</p>
        </div>
      <% } else { %>
        <div class="table-scroll">
          <table class="stats-table stack-mobile">
            <thead>
              <tr>
                <th>Rank</th>
                <th>Name</th>
                <th>Brier Score</th>
                <th>Bits Score</th>
                <th>Correct Tips</th>
                <th>Total Tips</th>
                <th>Tip Accuracy</th>
                <th>Margin MAE</th>
              </tr>
            </thead>
            <tbody>
              <% 
                let rank = 1;
                predictorStats.forEach(stats => {
                  if (stats.totalPredictions > 0) {
              %>
                <tr class="<%= stats.id === currentUser.id ? 'current-user' : '' %>">
                  <td data-label="Rank"><%= rank++ %></td>
                  <td class="stack-primary" data-label="Name"><%= stats.display_name %> <%= stats.id === currentUser.id ? '(You)' : '' %></td>
                  <td data-label="Brier Score"><%= stats.brierScore %></td>
                  <td data-label="Bits Score"><%= stats.bitsScore %></td>
                  <td data-label="Correct Tips"><%= stats.tipPoints %></td>
                  <td data-label="Total Tips"><%= stats.totalPredictions %></td>
                  <td data-label="Tip Accuracy"><%= stats.tipAccuracy %>%</td>
                  <td data-label="Margin MAE"><%= stats.marginMAE !== null ? stats.marginMAE : '-' %></td>
                </tr>
              <% 
                  }
                });
              %>
            </tbody>
          </table>
        </div>
        
        <div class="metrics-explanation">
          <h3>Understanding the Metrics</h3>
          <ul>
            <li><strong>Tip Accuracy:</strong> Percentage of correct tips. A full point is awarded if it was a draw.</li>
            <li><strong>Brier Score:</strong> Measures accuracy of probabilistic predictions - lower is better (0 is perfect).</li>
            <li><strong>Bits Score:</strong> Information-based scoring - higher is better.</li>
            <li><strong>Margin MAE:</strong> Mean Absolute Error for margin predictions - average difference between predicted and actual margins. Lower is better. Shows "-" if no margin predictions.</li>
          </ul>
        </div>
      <% } %>
    </div>
    
    <% if (rounds && rounds.length > 0) { %>
    <div class="round-selector">
      <h2>Select Round</h2>
      <div class="round-buttons">
        <% rounds.forEach(roundObj => { %>
          <button 
            class="round-button 
                   <%= roundObj.round_number === selectedRound ? 'selected' : '' %>
                   <%= roundObj.isCompleted ? 'completed' : '' %>
                   <%= roundObj.round_number === currentRound ? 'current' : '' %>"
            data-round="<%= roundObj.round_number %>"
          >
            <%= roundObj.round_number %>
          </button>
        <% }) %>
      </div>
    </div>
    <% } %>
    
    <div
      id="round-stats-container"
      class="<%= selectedRound && ((roundPredictorStats && roundPredictorStats.length > 0) || (cumulativePredictorStats && cumulativePredictorStats.length > 0)) ? '' : 'is-hidden' %>"
    >
      <div class="stats-card round-leaderboard">
        <h2 class="stats-heading" id="round-stats-heading">
          Round Performance - <%= selectedYear %> 
          <span id="round-display">
            <%= selectedRound === 'OR' ? 'Opening Round' : 
                isNaN(selectedRound) ? selectedRound : 
                'Round ' + selectedRound %>
          </span>
        </h2>
        
        <div id="round-stats-content" class="table-scroll">
          <% if (selectedRound && roundPredictorStats && roundPredictorStats.length > 0) { %>
            <% if (roundPredictorStats.every(stat => stat.totalPredictions === 0)) { %>
              <div class="no-stats">
                <p>No prediction results available for this round.</p>
              </div>
            <% } else { %>
              <table class="stats-table stack-mobile">
                <thead>
                  <tr>
                    <th>Rank</th>
                    <th>Name</th>
                    <th>Brier Score</th>
                    <th>Bits Score</th>
                    <th>Correct Tips</th>
                    <th>Total Tips</th>
                    <th>Tip Accuracy</th>
                    <th>Margin MAE</th>
                  </tr>
                </thead>
                <tbody>
                  <% 
                    let roundRank = 1;
                    roundPredictorStats.forEach(stats => {
                      if (stats.totalPredictions > 0) {
                  %>
                    <tr class="<%= stats.id === currentUser.id ? 'current-user' : '' %>">
                      <td data-label="Rank"><%= roundRank++ %></td>
                      <td class="stack-primary" data-label="Name"><%= stats.display_name %> <%= stats.id === currentUser.id ? '(You)' : '' %></td>
                      <td data-label="Brier Score"><%= stats.brierScore %></td>
                      <td data-label="Bits Score"><%= stats.bitsScore %></td>
                      <td data-label="Correct Tips"><%= stats.tipPoints %></td>
                      <td data-label="Total Tips"><%= stats.totalPredictions %></td>
                      <td data-label="Tip Accuracy"><%= stats.tipAccuracy %>%</td>
                      <td data-label="Margin MAE"><%= stats.marginMAE !== null ? stats.marginMAE : '-' %></td>
                    </tr>
                  <% 
                      }
                    });
                  %>
                </tbody>
              </table>
            <% } %>
          <% } %>
        </div>
      </div>

      <div class="stats-card round-leaderboard cumulative-leaderboard">
        <h2 class="stats-heading" id="cumulative-stats-heading">
          Cumulative Performance - <%= selectedYear %> Through
          <span id="cumulative-display">
            <%= selectedRound === 'OR' ? 'Opening Round' : 
                isNaN(selectedRound) ? selectedRound : 
                'Round ' + selectedRound %>
          </span>
        </h2>

        <div id="cumulative-stats-content" class="table-scroll">
          <% if (selectedRound && cumulativePredictorStats && cumulativePredictorStats.length > 0) { %>
            <% if (cumulativePredictorStats.every(stat => stat.totalPredictions === 0)) { %>
              <div class="no-stats">
                <p>No cumulative prediction results available through this round.</p>
              </div>
            <% } else { %>
              <table class="stats-table stack-mobile">
                <thead>
                  <tr>
                    <th>Rank</th>
                    <th>Name</th>
                    <th>Brier Score</th>
                    <th>Bits Score</th>
                    <th>Correct Tips</th>
                    <th>Total Tips</th>
                    <th>Tip Accuracy</th>
                    <th>Margin MAE</th>
                  </tr>
                </thead>
                <tbody>
                  <% 
                    let cumulativeRank = 1;
                    cumulativePredictorStats.forEach(stats => {
                      if (stats.totalPredictions > 0) {
                  %>
                    <tr class="<%= stats.id === currentUser.id ? 'current-user' : '' %>">
                      <td data-label="Rank"><%= cumulativeRank++ %></td>
                      <td class="stack-primary" data-label="Name"><%= stats.display_name %> <%= stats.id === currentUser.id ? '(You)' : '' %></td>
                      <td data-label="Brier Score"><%= stats.brierScore %></td>
                      <td data-label="Bits Score"><%= stats.bitsScore %></td>
                      <td data-label="Correct Tips"><%= stats.tipPoints %></td>
                      <td data-label="Total Tips"><%= stats.totalPredictions %></td>
                      <td data-label="Tip Accuracy"><%= stats.tipAccuracy %>%</td>
                      <td data-label="Margin MAE"><%= stats.marginMAE !== null ? stats.marginMAE : '-' %></td>
                    </tr>
                  <% 
                      }
                    });
                  %>
                </tbody>
              </table>
            <% } %>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="/js/stats.js"></script>
<%- include('partials/footer') %>
