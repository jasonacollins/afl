<%- include('partials/header') %>

<div class="container">
  <div class="welcome-section">
    <h1>Welcome to Dad's AFL Predictions</h1>
    
    <% if (!locals.user) { %>
      <div class="login-buttons">
        <a href="/login" class="button primary-button">Login</a>
      </div>
    <% } else { %>
      <div class="login-buttons">
        <a href="/predictions" class="button primary-button">Make Predictions</a>
      </div>
    <% } %>
  </div>

  <% if (locals.featuredPredictor) { %>
    <!-- Featured Predictor Performance Card -->
    <% if (locals.featuredPredictorStats) { %>
      <div class="performance-card">
        <div class="performance-header">
          <h2>Model Performance</h2>
          <div class="year-selector-performance">
            <select id="performance-year-selector" onchange="updatePerformanceYear(this.value)">
              <option value="<%= currentYear %>" selected><%= currentYear %></option>
              <% if (currentYear > 2022) { %>
                <% for (let year = currentYear - 1; year >= 2022; year--) { %>
                  <option value="<%= year %>"><%= year %></option>
                <% } %>
              <% } %>
            </select>
          </div>
        </div>
        <div class="model-selector">
          <select id="predictor-selector" onchange="updateSelectedPredictor(this.value)">
            <% homepageAvailablePredictors.forEach(predictor => { %>
              <option value="<%= predictor.predictor_id %>" <%= predictor.is_default_featured ? 'selected' : '' %>>
                <%= predictor.display_name %>
              </option>
            <% }) %>
          </select>
        </div>
        <div class="performance-metrics" id="performance-metrics-container">
          <div class="metric">
            <div class="metric-label">Tip Accuracy</div>
            <div class="metric-value"><%= featuredPredictorStats.tipAccuracy %>%</div>
            <div class="metric-detail"><%= featuredPredictorStats.tipPoints %>/<%= featuredPredictorStats.totalPredictions %> correct</div>
          </div>
          <div class="metric">
            <div class="metric-label">Brier Score</div>
            <div class="metric-value"><%= featuredPredictorStats.brierScore %></div>
            <div class="metric-detail">Lower is better</div>
          </div>
          <div class="metric">
            <div class="metric-label">Bits Score</div>
            <div class="metric-value"><%= featuredPredictorStats.bitsScore %></div>
            <div class="metric-detail">Higher is better</div>
          </div>
          <div class="metric">
            <div class="metric-label">Margin MAE</div>
            <div class="metric-value"><%= featuredPredictorStats.marginMAE !== null ? featuredPredictorStats.marginMAE : '-' %></div>
            <div class="metric-detail"><%= featuredPredictorStats.marginMAE !== null ? 'Lower is better' : 'No margin predictions' %></div>
          </div>
        </div>
      </div>
    <% } %>
    
    <div class="predictions-viewer">
      <h2>Featured Predictions</h2>
      
      <div class="header-controls">
        <div class="predictor-name">
          <%= featuredPredictor.display_name %>'s Predictions
        </div>
        
        <div class="round-selector">
          <h2>Select Round</h2>
          <div class="round-buttons">
            <% rounds.forEach(round => { %>
              <button 
                class="round-button 
                       <%= round.round_number === selectedRound ? 'selected' : '' %>
                       <%= round.isCompleted ? 'completed' : '' %>
                       <%= round.round_number === currentRound ? 'current' : '' %>"
                onclick="fetchRoundPredictions('<%= round.round_number %>')">
                <%= round.round_number %>
              </button>
            <% }) %>
          </div>
        </div>
      </div>
      
      <div id="predictions-table-container">
        <table class="predictions-table">
            <thead>
                <tr>
                <th style="text-align: left;">Match</th>
                <th style="text-align: center;">Result</th>
                <th style="text-align: center;">Prediction</th>
                <th style="text-align: center;">Win Accuracy</th>
                <th style="text-align: center;">Predicted Margin</th>
                <th style="text-align: center;">Margin Accuracy</th>
                </tr>
            </thead>
          <tbody>
            <% if (matches && matches.length > 0) { %>
              <% matches.forEach(match => { %>
                <tr>
                  <td class="team-names">
                    <div><%= match.home_team %> vs <%= match.away_team %></div>
                    <div style="font-size: 0.8rem; color: var(--light-text);"><%= match.venue %>, <%= match.match_date %></div>
                  </td>
                  <td class="score">
                    <% if (match.hscore !== null && match.ascore !== null) { %>
                      <%= match.hscore %> - <%= match.ascore %>
                    <% } else { %>
                      Upcoming
                    <% } %>
                  </td>
                  <td class="prediction">
                    <% if (predictions[match.match_id]) { %>
                        <% const prediction = predictions[match.match_id] %>
                        <% if (typeof prediction === 'object') { %>
                        <% if (prediction.probability > 50) { %>
                            <%= prediction.probability %>% <%= match.home_team %>
                        <% } else if (prediction.probability < 50) { %>
                            <%= 100 - prediction.probability %>% <%= match.away_team %>
                        <% } else { %>
                            50% draw (tipped: <%= prediction.tipped_team === 'home' ? match.home_team : match.away_team %>)
                        <% } %>
                        <% } else { %>
                        <% if (prediction > 50) { %>
                            <%= prediction %>% <%= match.home_team %>
                        <% } else if (prediction < 50) { %>
                            <%= 100 - prediction %>% <%= match.away_team %>
                        <% } else { %>
                            50% draw
                        <% } %>
                        <% } %>
                    <% } else { %>
                        No prediction
                    <% } %>
                  </td>
                  <td class="win-accuracy">
                    <% if (match.hscore !== null && match.ascore !== null && predictions[match.match_id] && match.metrics) { %>
                      <% if (match.metrics.correct) { %>
                        <div class="correct">✓ Correct</div>
                      <% } else if (match.metrics.partial) { %>
                        <div class="partial">◑ Draw</div>
                      <% } else { %>
                        <div class="incorrect">✗ Incorrect</div>
                      <% } %>
                      <div class="metrics">
                        Brier: <%= match.metrics.brierScore.toFixed(4) %> | Bits: <%= match.metrics.bitsScore.toFixed(4) %>
                      </div>
                    <% } else { %>
                      -
                    <% } %>
                  </td>
                  <td class="margin">
                    <% if (predictions[match.match_id] && predictions[match.match_id].predicted_margin !== null && predictions[match.match_id].predicted_margin !== undefined) { %>
                        <% const margin = predictions[match.match_id].predicted_margin %>
                        <% if (margin > 0) { %>
                            +<%= Math.abs(margin).toFixed(1) %> pts
                        <% } else if (margin < 0) { %>
                            -<%= Math.abs(margin).toFixed(1) %> pts
                        <% } else { %>
                            0.0 pts
                        <% } %>
                    <% } else { %>
                        -
                    <% } %>
                  </td>
                  <td class="margin-accuracy">
                    <% if (match.hscore !== null && match.ascore !== null && predictions[match.match_id] && predictions[match.match_id].predicted_margin !== null && predictions[match.match_id].predicted_margin !== undefined) { %>
                        <% const actualMargin = match.hscore - match.ascore %>
                        <% const predictedMargin = predictions[match.match_id].predicted_margin %>
                        <% const mae = Math.abs(actualMargin - predictedMargin) %>
                        MAE: <%= mae.toFixed(1) %>
                    <% } else { %>
                        -
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="6" style="text-align: center; padding: 2rem;">No matches available for this round</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  <% } %>

  <!-- ELO Chart Section -->
  <div class="elo-chart-section">
    <div class="elo-chart-controls">
      <h2>ELO Team Ratings</h2>
      
      <div class="chart-filter-controls">
        <div class="filter-group">
          <label>
            <input type="radio" name="chart-mode" value="year" checked> Year
          </label>
          <label>
            <input type="radio" name="chart-mode" value="yearRange"> Year Range
          </label>
        </div>
        
        <div id="year-controls" class="filter-group">
          <select id="year-selector" class="year-selector">
            <!-- Options will be populated by JavaScript -->
          </select>
        </div>
        
        <div id="year-range-controls" class="filter-group" style="display: none;">
          <div class="date-range-inputs">
            <select id="start-year" class="year-input">
              <!-- Options will be populated by JavaScript -->
            </select>
            <span>to</span>
            <select id="end-year" class="year-input">
              <!-- Options will be populated by JavaScript -->
            </select>
          </div>
        </div>
      </div>
    </div>
    
    <div id="elo-chart" class="elo-chart-container">
      <!-- Chart will be loaded here by JavaScript -->
    </div>
  </div>
</div>

<% if (locals.featuredPredictor) { %>
  <script>
    function fetchRoundPredictions(round) {
      // Update active button
      document.querySelectorAll('.round-button').forEach(btn => {
        btn.classList.remove('selected');
        if (btn.textContent.trim() === round) {
          btn.classList.add('selected');
        }
      });
      
      // Show loading state
      document.getElementById('predictions-table-container').innerHTML = 
        '<div style="text-align: center; padding: 2rem;">Loading predictions...</div>';
      
      // Get current selected predictor
      const selectedPredictorId = document.getElementById('predictor-selector').value;
      
      // Fetch predictions for this round and predictor
      fetch(`/featured-predictions/${round}?year=<%= currentYear %>&predictorId=${selectedPredictorId}`)
        .then(response => response.json())
        .then(data => {
          renderPredictionsTable(data.matches, data.predictions);
        })
        .catch(error => {
          console.error('Error fetching predictions:', error);
          document.getElementById('predictions-table-container').innerHTML = 
            '<div style="text-align: center; padding: 2rem; color: #666;">Error loading predictions</div>';
        });
    }
    
    function renderPredictionsTable(matches, predictions) {
      let tableHtml = `
        <table class="predictions-table">
          <thead>
            <tr>
            <th style="text-align: left;">Match</th>
            <th style="text-align: center;">Result</th>
            <th style="text-align: center;">Prediction</th>
            <th style="text-align: center;">Win Accuracy</th>
            <th style="text-align: center;">Predicted Margin</th>
            <th style="text-align: center;">Margin Accuracy</th>
            </tr>
          </thead>
          <tbody>
      `;
      
      if (matches && matches.length > 0) {
        matches.forEach(match => {
          // Format match date if available
          let matchDate = match.match_date;
          if (matchDate && matchDate.includes('T')) {
            try {
              const date = new Date(matchDate);
              matchDate = date.toLocaleDateString('en-AU', {
                day: '2-digit',
                month: '2-digit',
                year: 'numeric'
              });
            } catch (e) {
              console.error('Error formatting date:', e);
            }
          }
          
          // Get prediction
          let predictionHtml = 'No prediction';
          if (predictions[match.match_id]) {
          const prediction = predictions[match.match_id];
          let probability;
          let tippedTeam;
        
          if (typeof prediction === 'object') {
          probability = prediction.probability;
            tippedTeam = prediction.tipped_team;
          } else {
            probability = prediction;
            tippedTeam = null;
          }
        
          if (probability > 50) {
            predictionHtml = `${probability}% ${match.home_team}`;
          } else if (probability < 50) {
            predictionHtml = `${100 - probability}% ${match.away_team}`;
          } else { // exactly 50%
            if (tippedTeam) {
              predictionHtml = `50% draw (tipped: ${tippedTeam === 'home' ? match.home_team : match.away_team})`;
            } else {
             predictionHtml = `50% draw`;
            }
           }
         }
          
          // Result
          let resultHtml = 'Upcoming';
          if (match.hscore !== null && match.ascore !== null) {
            resultHtml = `${match.hscore} - ${match.ascore}`;
          }
          
          // Win Accuracy
          let winAccuracyHtml = '-';
          if (match.hscore !== null && match.ascore !== null && 
              predictions[match.match_id] && match.metrics) {
            
            if (match.metrics.correct) {
              winAccuracyHtml = `<div class="correct">✓ Correct</div>`;
            } else if (match.metrics.partial) {
              winAccuracyHtml = `<div class="partial">◑ Draw</div>`;
            } else {
              winAccuracyHtml = `<div class="incorrect">✗ Incorrect</div>`;
            }
            
            winAccuracyHtml += `
              <div class="metrics">
                Brier: ${match.metrics.brierScore.toFixed(4)} | 
                Bits: ${match.metrics.bitsScore.toFixed(4)}
              </div>
            `;
          }
          
          // Margin
          let marginHtml = '-';
          if (predictions[match.match_id] && predictions[match.match_id].predicted_margin !== null && 
              predictions[match.match_id].predicted_margin !== undefined) {
            const margin = predictions[match.match_id].predicted_margin;
            if (margin > 0) {
              marginHtml = `+${Math.abs(margin).toFixed(1)} pts`;
            } else if (margin < 0) {
              marginHtml = `-${Math.abs(margin).toFixed(1)} pts`;
            } else {
              marginHtml = `0.0 pts`;
            }
          }
          
          // Margin Accuracy
          let marginAccuracyHtml = '-';
          if (match.hscore !== null && match.ascore !== null && 
              predictions[match.match_id] && predictions[match.match_id].predicted_margin !== null && 
              predictions[match.match_id].predicted_margin !== undefined) {
            const actualMargin = match.hscore - match.ascore;
            const predictedMargin = predictions[match.match_id].predicted_margin;
            const mae = Math.abs(actualMargin - predictedMargin);
            marginAccuracyHtml = `MAE: ${mae.toFixed(1)}`;
          }
          
          tableHtml += `
            <tr>
              <td class="team-names">
                <div>${match.home_team} vs ${match.away_team}</div>
                <div style="font-size: 0.8rem; color: var(--light-text);">${match.venue}, ${matchDate}</div>
              </td>
              <td class="score">${resultHtml}</td>
              <td class="prediction">${predictionHtml}</td>
              <td class="win-accuracy">${winAccuracyHtml}</td>
              <td class="margin">${marginHtml}</td>
              <td class="margin-accuracy">${marginAccuracyHtml}</td>
            </tr>
          `;
        });
      } else {
        tableHtml += `
          <tr>
            <td colspan="6" style="text-align: center; padding: 2rem;">No matches available for this round</td>
          </tr>
        `;
      }
      
      tableHtml += `
          </tbody>
        </table>
      `;
      
      document.getElementById('predictions-table-container').innerHTML = tableHtml;
    }
    
    // Function to update performance card when year or predictor changes
    function updatePerformanceData(selectedYear = null, selectedPredictorId = null) {
      const container = document.getElementById('performance-metrics-container');
      
      // Get current values if not provided
      if (!selectedYear) {
        selectedYear = document.getElementById('performance-year-selector').value;
      }
      if (!selectedPredictorId) {
        selectedPredictorId = document.getElementById('predictor-selector').value;
      }
      
      // Show loading state
      container.innerHTML = '<div style="text-align: center; padding: 2rem; color: #666;">Loading performance data...</div>';
      
      // Fetch performance data for selected year and predictor
      fetch(`/api/predictor-stats?year=${selectedYear}&predictorId=${selectedPredictorId}`)
        .then(response => response.json())
        .then(data => {
          if (data.success && data.stats) {
            updatePerformanceMetrics(data.stats);
          } else {
            container.innerHTML = '<div style="text-align: center; padding: 2rem; color: #666;">No performance data available for this year.</div>';
          }
        })
        .catch(error => {
          console.error('Error loading performance data:', error);
          container.innerHTML = '<div style="text-align: center; padding: 2rem; color: #666;">Error loading performance data.</div>';
        });
    }
    
    // Function to update performance card when year changes
    function updatePerformanceYear(selectedYear) {
      updatePerformanceData(selectedYear, null);
    }
    
    // Function to update performance card when predictor changes
    function updateSelectedPredictor(selectedPredictorId) {
      updatePerformanceData(null, selectedPredictorId);
      
      // Also refresh the predictions table for the currently selected round
      const selectedRoundButton = document.querySelector('.round-button.selected');
      if (selectedRoundButton) {
        const currentRound = selectedRoundButton.textContent.trim();
        fetchRoundPredictions(currentRound);
      }
    }
    
    // Function to update performance metrics display
    function updatePerformanceMetrics(stats) {
      const container = document.getElementById('performance-metrics-container');
      
      const metricsHtml = `
        <div class="metric">
          <div class="metric-label">Tip Accuracy</div>
          <div class="metric-value">${stats.tipAccuracy}%</div>
          <div class="metric-detail">${stats.tipPoints}/${stats.totalPredictions} correct</div>
        </div>
        <div class="metric">
          <div class="metric-label">Brier Score</div>
          <div class="metric-value">${stats.brierScore}</div>
          <div class="metric-detail">Lower is better</div>
        </div>
        <div class="metric">
          <div class="metric-label">Bits Score</div>
          <div class="metric-value">${stats.bitsScore}</div>
          <div class="metric-detail">Higher is better</div>
        </div>
        <div class="metric">
          <div class="metric-label">Margin MAE</div>
          <div class="metric-value">${stats.marginMAE !== null ? stats.marginMAE : '-'}</div>
          <div class="metric-detail">${stats.marginMAE !== null ? 'Lower is better' : 'No margin predictions'}</div>
        </div>
      `;
      
      container.innerHTML = metricsHtml;
    }
  </script>
<% } %>

<style>
  .welcome-section {
    text-align: center;
    margin-bottom: 2rem;
    padding: 2rem;
    background-color: white;
    border-radius: 8px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  }
  
  .welcome-section h1 {
    margin-bottom: 1rem;
  }
  
  .welcome-section p {
    margin-bottom: 1.5rem;
    font-size: 1.1rem;
  }
  
  .login-buttons {
    margin-top: 1rem;
  }
  
  .login-buttons .button {
    display: inline-block;
    width: auto;
    min-width: 150px;
  }
  
  .predictions-viewer {
    background-color: white;
    border-radius: 8px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    padding: 1.5rem;
    width: 100%;
  }
  
  .header-controls {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
    margin-bottom: 1rem;
  }
  
  .predictor-name {
    font-weight: bold;
    color: var(--primary-color);
  }
  
  .round-selector {
    margin-bottom: 1rem;
  }
  
  .round-selector h2 {
    margin-bottom: 0.5rem;
  }
  
  .round-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  
  .round-button {
    background-color: var(--background-light);
    border: 1px solid var(--border-color);
    padding: 0.4rem 0.75rem;
    border-radius: 4px;
    cursor: pointer;
    font-size: 0.8rem;
  }
  
  .round-button:hover {
    background-color: #f0f0f0;
  }
  
  .round-button.completed:not(.selected) {
    background-color: #28a745;
    border-color: #28a745;
    color: white;
  }
  
  .round-button.current:not(.selected) {
    background-color: #007bff;
    border-color: #007bff;
    color: white;
  }
  
  .round-button.selected {
    background-color: #dc3545 !important;
    border-color: #dc3545 !important;
    color: white !important;
  }
  
  .predictions-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }
  
  .predictions-table th,
  .predictions-table td {
    padding: 0.75rem;
    border-bottom: 1px solid var(--border-color);
    vertical-align: middle;
  }
  
  /* Match column - align left */
  .predictions-table th:nth-child(1),
  .predictions-table td:nth-child(1) {
    text-align: left;
  }
    
  /* Result column - align center */
  .predictions-table th:nth-child(2),
  .predictions-table td:nth-child(2) {
    text-align: center;
  }
    
    /* Prediction column - align center */
    .predictions-table th:nth-child(3),
    .predictions-table td:nth-child(3) {
    text-align: center;
  }
    
  /* Win Accuracy column - align center */
  .predictions-table th:nth-child(4),
  .predictions-table td:nth-child(4) {
    text-align: center;
  }
    
  /* Margin column - align center */
  .predictions-table th:nth-child(5),
  .predictions-table td:nth-child(5) {
    text-align: center;
  }
    
  /* Margin Accuracy column - align center */
  .predictions-table th:nth-child(6),
  .predictions-table td:nth-child(6) {
    text-align: center;
  }

  .predictions-table tr:hover {
    background-color: rgba(0, 0, 0, 0.02);
  }
  
  .team-names {
    font-weight: 600;
    text-align: left !important;
  }
  
  .score {
    text-align: center;
    font-weight: 600;
  }
  
  .prediction {
    text-align: center;
  }
  
  .win-accuracy {
    text-align: center;
  }
  
  .margin {
    text-align: center;
    font-weight: 600;
    font-size: 0.9rem;
  }
  
  .margin-accuracy {
    text-align: center;
    font-size: 0.9rem;
  }
  
  .metrics {
    font-size: 0.8rem;
    color: var(--light-text);
  }
  
  .correct {
    color: var(--success-color);
    font-weight: bold;
  }
  
  .incorrect {
    color: var(--error-color);
    font-weight: bold;
  }
  
  .partial {
    color: var(--warning-color);
    font-weight: bold;
  }
  
  /* Performance Card Styles */
  .performance-card {
    background-color: white;
    border-radius: 8px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    padding: 1.5rem;
    margin-bottom: 2rem;
    border-left: 4px solid var(--primary-color);
  }
  
  .performance-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
    gap: 1rem;
  }
  
  .performance-card h2 {
    margin: 0;
    color: var(--primary-color);
    font-size: 1.3rem;
  }
  
  .model-selector {
    display: flex;
    justify-content: center;
    margin-bottom: 1.5rem;
  }
  
  .model-selector select {
    padding: 0.5rem 0.8rem;
    border: 1px solid var(--border-color);
    border-radius: 4px;
    background-color: white;
    color: var(--text-color);
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    width: auto;
    text-align: center;
  }
  
  .model-selector select:focus {
    outline: none;
    border-color: var(--primary-color);
  }
  
  .year-selector-performance {
    display: flex;
    align-items: center;
  }
  
  .year-selector-performance select {
    padding: 0.4rem 0.8rem;
    border: 1px solid var(--border-color);
    border-radius: 4px;
    background-color: white;
    color: var(--text-color);
    font-size: 0.9rem;
    cursor: pointer;
  }
  
  .year-selector-performance select:focus {
    outline: none;
    border-color: var(--primary-color);
  }
  
  .performance-metrics {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    max-width: 900px;
    margin: 0 auto;
  }
  
  .metric {
    text-align: center;
    padding: 1rem;
    background-color: var(--background-light);
    border-radius: 6px;
    transition: transform 0.2s ease;
  }
  
  .metric:hover {
    transform: translateY(-2px);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }
  
  .metric-label {
