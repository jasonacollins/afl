<%- include('partials/header') %>

<div class="container">
  <div class="tab-navigation">
    <a href="/admin" class="tab">Predictor Management</a>
    <a href="/admin/user-predictions" class="tab">Manage User Predictions</a>
    <a href="/admin/scripts" class="tab active">Scripts</a>
    <a href="/admin/operations" class="tab">Operations</a>
  </div>

  <% if (locals.success) { %>
    <div class="alert success"><%= success %></div>
  <% } %>

  <% if (locals.error) { %>
    <div class="alert error"><%= error %></div>
  <% } %>

  <div id="scriptsPageError" class="alert error is-hidden"></div>

  <div id="activeRunBanner" class="alert warning is-hidden"></div>

  <div class="admin-container scripts-layout">
    <div class="admin-section">
      <p>Only one script can run at a time. Each run is stored in job history.</p>

      <div class="script-cards">
        <div class="script-card">
          <h3>Sync Games</h3>
          <p>Sync fixtures and game metadata from Squiggle.</p>
          <form class="script-run-form" data-script-key="sync-games">
            <div class="form-group">
              <label for="syncYear">Year (optional)</label>
              <input type="number" id="syncYear" name="year" min="1990">
            </div>
            <details class="script-advanced">
              <summary>Advanced</summary>
              <div class="form-group">
                <label for="syncRound">Round</label>
                <input type="text" id="syncRound" name="round" placeholder="e.g. 1 or OR">
              </div>
              <div class="form-group">
                <label for="syncGameId">Game ID</label>
                <input type="number" id="syncGameId" name="gameId" min="1">
              </div>
              <div class="form-group">
                <label for="syncTeamId">Team ID</label>
                <input type="number" id="syncTeamId" name="teamId" min="1">
              </div>
              <div class="form-group">
                <label for="syncComplete">Complete %</label>
                <input type="number" id="syncComplete" name="complete" min="0" max="100">
              </div>
            </details>
            <button type="submit" class="button primary-button">Run Sync Games</button>
          </form>
        </div>

        <div class="script-card">
          <h3>API Refresh</h3>
          <p>Refresh fixture and completed score data for a single year.</p>
          <form class="script-run-form" data-script-key="api-refresh">
            <div class="form-group">
              <label for="apiRefreshYear">Year</label>
              <input type="number" id="apiRefreshYear" name="year" min="1990" required>
            </div>
            <div class="form-group checkbox">
              <input type="checkbox" id="apiRefreshForce" name="forceScoreUpdate">
              <label for="apiRefreshForce">Force score update</label>
            </div>
            <button type="submit" class="button primary-button">Run API Refresh</button>
          </form>
        </div>

        <div class="script-card">
          <h3>Predictions</h3>
          <p>Generate predictions and write to selected predictor.</p>
          <form class="script-run-form" data-script-key="combined-predictions">
            <div class="form-group">
              <label for="combinedStartYear">Start Year</label>
              <input type="number" id="combinedStartYear" name="startYear" min="1990" required>
            </div>
            <div class="form-group">
              <label for="predictionsMode">Model Type</label>
              <select id="predictionsMode" name="predictionMode">
                <option value="optimized">Win + Optimised Margin</option>
                <option value="margin">Margin-only (Derive Win %)</option>
              </select>
            </div>
            <div class="form-group" data-predictions-mode-panel="margin">
              <label for="combinedMarginModelPath">Margin Model</label>
              <select id="combinedMarginModelPath" name="marginModelPath" required></select>
            </div>
            <div class="form-group" data-predictions-mode-panel="margin">
              <label for="combinedPredictorId">Predictor</label>
              <select id="combinedPredictorId" name="predictorId" required></select>
            </div>
            <div class="form-group" data-predictions-mode-panel="optimized">
              <label for="optimizedWinModelPath">Win Model</label>
              <select id="optimizedWinModelPath" name="optimizedWinModelPath"></select>
            </div>
            <div class="form-group" data-predictions-mode-panel="optimized">
              <label for="optimizedMarginMethodsPath">Margin Methods</label>
              <select id="optimizedMarginMethodsPath" name="optimizedMarginMethodsPath"></select>
            </div>
            <div class="form-group" data-predictions-mode-panel="optimized">
              <label for="optimizedPredictorId">Predictor</label>
              <select id="optimizedPredictorId" name="optimizedPredictorId"></select>
            </div>
            <div class="form-group checkbox" data-predictions-mode-panel="optimized">
              <input type="checkbox" id="optimizedFutureOnly" name="optimizedFutureOnly" checked>
              <label for="optimizedFutureOnly">Predict future games only</label>
            </div>
            <details class="script-advanced">
              <summary>Advanced</summary>
              <div class="form-group" data-predictions-mode-panel="margin">
                <label for="combinedDbPath">DB Path</label>
                <input type="text" id="combinedDbPath" name="dbPath" placeholder="data/database/afl_predictions.db">
              </div>
              <div class="form-group" data-predictions-mode-panel="margin">
                <label for="combinedOutputDir">Output Directory</label>
                <input type="text" id="combinedOutputDir" name="outputDir" placeholder="data/predictions/margin">
              </div>
              <div class="form-group checkbox" data-predictions-mode-panel="margin">
                <input type="checkbox" id="combinedSaveToDb" name="saveToDb" checked>
                <label for="combinedSaveToDb">Save predictions to database</label>
              </div>
              <div class="form-group checkbox" data-predictions-mode-panel="margin">
                <input type="checkbox" id="combinedOverrideCompleted" name="overrideCompleted">
                <label for="combinedOverrideCompleted">Override completed/started matches</label>
              </div>
              <div class="form-group" data-predictions-mode-panel="optimized">
                <label for="optimizedDbPath">DB Path</label>
                <input type="text" id="optimizedDbPath" name="optimizedDbPath" placeholder="data/database/afl_predictions.db">
              </div>
              <div class="form-group" data-predictions-mode-panel="optimized">
                <label for="optimizedOutputDir">Output Directory</label>
                <input type="text" id="optimizedOutputDir" name="optimizedOutputDir" placeholder="data/predictions/win">
              </div>
              <div class="form-group checkbox" data-predictions-mode-panel="optimized">
                <input type="checkbox" id="optimizedSaveToDb" name="optimizedSaveToDb" checked>
                <label for="optimizedSaveToDb">Save predictions to database</label>
              </div>
              <div class="form-group checkbox" data-predictions-mode-panel="optimized">
                <input type="checkbox" id="optimizedOverrideCompleted" name="optimizedOverrideCompleted">
                <label for="optimizedOverrideCompleted">Override completed/started matches</label>
              </div>
              <div class="form-group" data-predictions-mode-panel="optimized">
                <label for="optimizedMethodOverride">Method Override (optional)</label>
                <input type="text" id="optimizedMethodOverride" name="optimizedMethodOverride" placeholder="simple, linear, or diminishing_returns">
              </div>
              <div class="form-group checkbox" data-predictions-mode-panel="optimized">
                <input type="checkbox" id="optimizedAllowModelMismatch" name="optimizedAllowModelMismatch">
                <label for="optimizedAllowModelMismatch">Allow model mismatch (unsafe)</label>
              </div>
            </details>
            <button type="submit" class="button primary-button">Run Predictions</button>
          </form>
        </div>

        <div class="script-card">
          <h3>Train Model</h3>
          <p>Choose what to optimise, then run training.</p>
          <div class="form-group">
            <label for="trainOptimizationTarget">Optimise For</label>
            <select id="trainOptimizationTarget">
              <option value="win">Win Probability</option>
              <option value="margin">Margin</option>
            </select>
          </div>

          <div data-train-mode-panel="win">
            <form class="script-run-form" data-script-key="win-train">
              <div class="form-group">
                <label for="winTrainStartYear">Start Year</label>
                <input type="number" id="winTrainStartYear" name="startYear" min="1990" placeholder="1990">
              </div>
              <div class="form-group">
                <label for="winTrainEndYear">End Year</label>
                <input type="number" id="winTrainEndYear" name="endYear" min="1990">
              </div>
              <details class="script-advanced">
                <summary>Advanced</summary>
                <div class="form-group">
                  <label for="winTrainDbPath">DB Path</label>
                  <input type="text" id="winTrainDbPath" name="dbPath" placeholder="data/database/afl_predictions.db">
                </div>
                <div class="form-group">
                  <label for="winTrainOutputDir">Output Directory</label>
                  <input type="text" id="winTrainOutputDir" name="outputDir" placeholder="data/models/win">
                </div>
                <div class="form-group checkbox">
                  <input type="checkbox" id="winTrainNoTuneParameters" name="noTuneParameters">
                  <label for="winTrainNoTuneParameters">Skip parameter tuning</label>
                </div>
                <div class="form-group">
                  <label for="winTrainCvFolds">CV Folds</label>
                  <input type="number" id="winTrainCvFolds" name="cvFolds" min="2" max="10" placeholder="3">
                </div>
                <div class="form-group">
                  <label for="winTrainMaxCombinations">Max Combinations</label>
                  <input type="number" id="winTrainMaxCombinations" name="maxCombinations" min="1" max="5000" placeholder="500">
                </div>
                <div class="form-group">
                  <label for="winTrainParamsFile">Params File (optional)</label>
                  <select id="winTrainParamsFile" name="paramsFile"></select>
                </div>
                <div class="form-group">
                  <label for="winTrainMarginParams">Margin Params File (optional)</label>
                  <select id="winTrainMarginParams" name="marginParams"></select>
                </div>
              </details>
              <button type="submit" class="button primary-button">Run Win Training</button>
            </form>

            <form class="script-run-form" data-script-key="win-margin-methods-optimize">
              <p><strong>Step 2 (Testing):</strong> Optimise margin derivation methods for a trained win model.</p>
              <div class="form-group">
                <label for="winMarginMethodsOptimizeEloParamsPath">Win Model / Params</label>
                <select id="winMarginMethodsOptimizeEloParamsPath" name="eloParamsPath" required></select>
              </div>
              <div class="form-group">
                <label for="winMarginMethodsOptimizeStartYear">Start Year</label>
                <input type="number" id="winMarginMethodsOptimizeStartYear" name="startYear" min="1990" placeholder="1990">
              </div>
              <div class="form-group">
                <label for="winMarginMethodsOptimizeEndYear">End Year</label>
                <input type="number" id="winMarginMethodsOptimizeEndYear" name="endYear" min="1990">
              </div>
              <details class="script-advanced">
                <summary>Advanced</summary>
                <div class="form-group">
                  <label for="winMarginMethodsOptimizeNCalls">N Calls</label>
                  <input type="number" id="winMarginMethodsOptimizeNCalls" name="nCalls" min="1" max="5000" placeholder="100">
                </div>
                <div class="form-group">
                  <label for="winMarginMethodsOptimizeRandomSeed">Random Seed</label>
                  <input type="number" id="winMarginMethodsOptimizeRandomSeed" name="randomSeed" placeholder="42">
                </div>
                <div class="form-group">
                  <label for="winMarginMethodsOptimizeDbPath">DB Path</label>
                  <input type="text" id="winMarginMethodsOptimizeDbPath" name="dbPath" placeholder="data/database/afl_predictions.db">
                </div>
                <div class="form-group">
                  <label for="winMarginMethodsOptimizeOutputPath">Output Path</label>
                  <input type="text" id="winMarginMethodsOptimizeOutputPath" name="outputPath" placeholder="data/models/win/optimal_margin_methods_trained_to_YYYY.json">
                </div>
              </details>
              <button type="submit" class="button primary-button">Run Win Margin Methods Optimisation</button>
            </form>
          </div>

          <div data-train-mode-panel="margin">
            <form class="script-run-form" data-script-key="margin-optimize">
              <p><strong>Step 1:</strong> Optimise margin parameters.</p>
              <div class="form-group">
                <label for="marginOptimizeStartYear">Start Year</label>
                <input type="number" id="marginOptimizeStartYear" name="startYear" min="1990" placeholder="1990">
              </div>
              <div class="form-group">
                <label for="marginOptimizeEndYear">End Year</label>
                <input type="number" id="marginOptimizeEndYear" name="endYear" min="1990">
              </div>
              <details class="script-advanced">
                <summary>Advanced</summary>
                <div class="form-group">
                  <label for="marginOptimizeMaxCombinations">Max Combinations</label>
                  <input type="number" id="marginOptimizeMaxCombinations" name="maxCombinations" min="1" max="5000" placeholder="500">
                </div>
                <div class="form-group">
                  <label for="marginOptimizeDbPath">DB Path</label>
                  <input type="text" id="marginOptimizeDbPath" name="dbPath" placeholder="data/database/afl_predictions.db">
                </div>
                <div class="form-group">
                  <label for="marginOptimizeOutputPath">Output Path</label>
                  <input type="text" id="marginOptimizeOutputPath" name="outputPath" placeholder="data/models/margin/optimal_margin_only_elo_params_trained_to_YYYY.json">
                </div>
              </details>
              <button type="submit" class="button primary-button">Run Margin Optimisation</button>
            </form>

            <form class="script-run-form" data-script-key="margin-train">
              <p><strong>Step 2:</strong> Train margin model using an optimised params file.</p>
              <div class="form-group">
                <label for="marginTrainParamsFile">Params File</label>
                <select id="marginTrainParamsFile" name="paramsFile" required></select>
              </div>
              <div class="form-group">
                <label for="marginTrainStartYear">Start Year</label>
                <input type="number" id="marginTrainStartYear" name="startYear" min="1990" placeholder="1990">
              </div>
              <div class="form-group">
                <label for="marginTrainEndYear">End Year</label>
                <input type="number" id="marginTrainEndYear" name="endYear" min="1990" placeholder="2024">
              </div>
              <details class="script-advanced">
                <summary>Advanced</summary>
                <div class="form-group">
                  <label for="marginTrainDbPath">DB Path</label>
                  <input type="text" id="marginTrainDbPath" name="dbPath" placeholder="data/database/afl_predictions.db">
                </div>
                <div class="form-group">
                  <label for="marginTrainOutputDir">Output Directory</label>
                  <input type="text" id="marginTrainOutputDir" name="outputDir" placeholder="data/models/margin">
                </div>
              </details>
              <button type="submit" class="button primary-button">Run Margin Training</button>
            </form>
          </div>
        </div>

        <div class="script-card">
          <h3>ELO History Generator</h3>
          <p>Generate chart history from the selected model (full rebuild or incremental append).</p>
          <form class="script-run-form" data-script-key="elo-history">
            <div class="form-group">
              <label for="historyModelPath">Model</label>
              <select id="historyModelPath" name="modelPath" required></select>
            </div>
            <div class="form-group">
              <label for="historyMode">Mode</label>
              <select id="historyMode" name="mode">
                <option value="incremental">Incremental (append new completed matches)</option>
                <option value="full">Full rebuild</option>
              </select>
            </div>
            <details class="script-advanced">
              <summary>Advanced</summary>
              <div class="form-group">
                <label for="historySeedStartYear">Seed Start Year</label>
                <input type="number" id="historySeedStartYear" name="seedStartYear" min="1990">
              </div>
              <div class="form-group">
                <label for="historySeedEndYear">Seed End Year (optional)</label>
                <input type="number" id="historySeedEndYear" name="seedEndYear" min="1990">
              </div>
              <div class="form-group">
                <label for="historyOutputStartYear">Output Start Year</label>
                <input type="number" id="historyOutputStartYear" name="outputStartYear" min="1990">
              </div>
              <div class="form-group">
                <label for="historyOutputEndYear">Output End Year (optional)</label>
                <input type="number" id="historyOutputEndYear" name="outputEndYear" min="1990">
              </div>
              <div class="form-group">
                <label for="historyDbPath">DB Path</label>
                <input type="text" id="historyDbPath" name="dbPath" placeholder="data/database/afl_predictions.db">
              </div>
              <div class="form-group">
                <label for="historyOutputDir">Output Directory</label>
                <input type="text" id="historyOutputDir" name="outputDir" placeholder="data/historical">
              </div>
              <div class="form-group">
                <label for="historyOutputPrefix">Output Prefix</label>
                <input type="text" id="historyOutputPrefix" name="outputPrefix" placeholder="afl_elo_complete_history">
              </div>
            </details>
            <button type="submit" class="button primary-button">Run ELO History</button>
          </form>
        </div>

        <div class="script-card">
          <h3>Season Simulation</h3>
          <p>Run Monte Carlo simulation and output JSON results.</p>
          <form class="script-run-form" data-script-key="season-simulation">
            <div class="form-group">
              <label for="simYear">Year</label>
              <input type="number" id="simYear" name="year" min="1990" required>
            </div>
            <div class="form-group">
              <label for="simModelPath">Margin Model</label>
              <select id="simModelPath" name="modelPath" required></select>
            </div>
            <details class="script-advanced">
              <summary>Advanced</summary>
              <div class="form-group">
                <label for="simDbPath">DB Path</label>
                <input type="text" id="simDbPath" name="dbPath" placeholder="data/database/afl_predictions.db">
              </div>
              <div class="form-group">
                <label for="simNumSimulations">Simulations</label>
                <input type="number" id="simNumSimulations" name="numSimulations" min="1000" max="200000" placeholder="50000">
              </div>
              <div class="form-group checkbox">
                <input type="checkbox" id="simFromScratch" name="fromScratch">
                <label for="simFromScratch">From scratch</label>
              </div>
              <div class="form-group">
                <label for="simOutput">Output File</label>
                <input type="text" id="simOutput" name="output" placeholder="data/simulations/season_simulation_YYYY.json">
              </div>
            </details>
            <button type="submit" class="button primary-button">Run Simulation</button>
          </form>
        </div>
      </div>
    </div>

    <div class="admin-section">
      <h2>Run History</h2>
      <div class="history-table-wrapper">
        <table class="admin-table" id="scriptRunHistoryTable">
          <thead>
            <tr>
              <th>ID</th>
              <th>Script</th>
              <th>Status</th>
              <th>Started</th>
              <th>Finished</th>
              <th>By</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody id="scriptRunHistoryBody">
            <tr>
              <td colspan="7">Loading history...</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <div class="admin-section">
      <h2>Run Logs</h2>
      <p id="logRunLabel">Select a run from history to view logs.</p>
      <pre id="scriptLogsOutput" class="script-logs-output">No logs loaded.</pre>
    </div>
  </div>
</div>

<script src="<%= assetPath('/js/main.js') %>"></script>
<script src="<%= assetPath('/js/admin-scripts.js') %>"></script>

<%- include('partials/footer') %>
