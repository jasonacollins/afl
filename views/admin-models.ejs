<%- include('partials/header') %>

<div class="container">
  <div class="tab-navigation">
    <a href="/admin" class="tab">Predictor Management</a>
    <a href="/admin/user-predictions" class="tab">Manage User Predictions</a>
    <a href="/admin/models" class="tab active">Models</a>
    <a href="/admin/data" class="tab">Data</a>
  </div>

  <% if (locals.success) { %>
    <div class="alert success"><%= success %></div>
  <% } %>

  <% if (locals.error) { %>
    <div class="alert error"><%= error %></div>
  <% } %>

  <div id="scriptsPageError" class="alert error is-hidden"></div>

  <div id="activeRunBanner" class="alert warning is-hidden"></div>

  <div class="admin-container scripts-layout" data-run-scope="models">
    <div class="admin-section scripts-catalog-section">
      <details id="catalogPanel" class="catalog-panel">
        <summary>
          <span>Model And Output Catalogue</span>
          <span id="catalogResultCount" class="catalog-result-count">Loading...</span>
        </summary>

        <div class="catalog-toolbar">
          <div class="form-group">
            <label for="catalogScopeFilter">Catalogue</label>
            <select id="catalogScopeFilter">
              <option value="models">Model artifacts</option>
              <option value="outputs">Generated outputs</option>
              <option value="all">Everything</option>
            </select>
          </div>
          <div class="form-group">
            <label for="catalogKindFilter">Type</label>
            <select id="catalogKindFilter">
              <option value="">All types</option>
            </select>
          </div>
          <div class="form-group">
            <label for="catalogSearch">Search</label>
            <input type="text" id="catalogSearch" placeholder="Year, metric, filename, model type">
          </div>
        </div>

        <div id="catalogList" class="catalog-list">
          <p class="catalog-empty">Loading catalogue...</p>
        </div>
      </details>
    </div>

    <div class="admin-section workflow-shell">
      <h2>Model Workflows</h2>
      <p>Only one run can be active at a time. The catalogue above is reference material; start from a task unless you already know the exact artifact you need.</p>

      <div class="workflow-launcher" role="tablist" aria-label="Model workflow tasks">
        <button type="button" class="workflow-launcher-button is-active" data-workflow-target="predictionsWorkflow" role="tab" aria-selected="true">
          <span>Make predictions</span>
          <small>Publish future tips</small>
        </button>
        <button type="button" class="workflow-launcher-button" data-workflow-target="trainingWorkflow" role="tab" aria-selected="false">
          <span>Train model</span>
          <small>Create model artifacts</small>
        </button>
        <button type="button" class="workflow-launcher-button" data-workflow-target="simulationWorkflow" role="tab" aria-selected="false">
          <span>Run simulation</span>
          <small>Season projections</small>
        </button>
        <button type="button" class="workflow-launcher-button" data-workflow-target="historyWorkflow" role="tab" aria-selected="false">
          <span>Update ELO history</span>
          <small>Chart data</small>
        </button>
      </div>

      <section id="predictionsWorkflow" class="workflow-panel" data-workflow-panel>
        <div class="workflow-panel-heading">
          <div>
            <h3>Make predictions</h3>
            <p>Use the recommended bundle to generate normal CSV output and publish future match predictions to the selected predictor.</p>
          </div>
          <span class="workflow-status-pill">Recommended first</span>
        </div>

        <form class="script-run-form guided-prediction-form" data-script-key="guided-predictions">
          <input type="hidden" id="guidedPredictionSaveToDb" name="saveToDb" value="true">
          <input type="hidden" id="guidedPredictionFutureOnly" name="futureOnly" value="true">

          <div class="workflow-form-grid">
            <div class="form-group">
              <label for="guidedPredictionMode">Prediction mode</label>
              <select id="guidedPredictionMode" name="predictionMode">
                <option value="recommended">Recommended bundle</option>
                <option value="marginOnly">Margin-only</option>
              </select>
            </div>
            <div class="form-group">
              <label for="guidedPredictionYear">Season</label>
              <input type="number" id="guidedPredictionYear" name="startYear" min="1990" required>
            </div>
            <div class="form-group">
              <label for="guidedPredictionPredictorId">Target predictor</label>
              <select id="guidedPredictionPredictorId" name="predictorId" required></select>
            </div>
            <div class="form-group" data-guided-prediction-mode-panel="recommended">
              <label for="guidedPredictionWinModelPath">Win model</label>
              <select id="guidedPredictionWinModelPath" name="winModelPath"></select>
            </div>
            <div class="form-group" data-guided-prediction-mode-panel="recommended">
              <label for="guidedPredictionMarginMethodsPath">Margin methods</label>
              <select id="guidedPredictionMarginMethodsPath" name="marginMethodsPath"></select>
            </div>
            <div class="form-group" data-guided-prediction-mode-panel="marginOnly">
              <label for="guidedPredictionMarginModelPath">Margin model</label>
              <select id="guidedPredictionMarginModelPath" name="modelPath"></select>
            </div>
          </div>

          <div id="guidedPredictionReview" class="workflow-review" aria-live="polite">
            <h4>This will change</h4>
            <dl>
              <div>
                <dt>Predictor</dt>
                <dd id="guidedPredictionReviewPredictor">Loading...</dd>
              </div>
              <div>
                <dt>Season</dt>
                <dd id="guidedPredictionReviewSeason">Loading...</dd>
              </div>
              <div>
                <dt>Model artifacts</dt>
                <dd id="guidedPredictionReviewArtifacts">Loading...</dd>
              </div>
              <div>
                <dt>Output</dt>
                <dd id="guidedPredictionReviewOutput">Loading...</dd>
              </div>
            </dl>
            <p id="guidedPredictionReviewSafety" class="workflow-safe-note">Completed or already-started matches are left untouched.</p>
          </div>

          <details id="guidedPredictionAdvanced" class="script-advanced danger-zone">
            <summary>Dangerous options</summary>
            <div class="workflow-form-grid">
              <div class="form-group checkbox">
                <input type="checkbox" id="guidedPredictionOverrideCompleted" name="overrideCompleted">
                <label for="guidedPredictionOverrideCompleted">Overwrite completed or already-started matches</label>
              </div>
              <div class="form-group checkbox" data-guided-prediction-mode-panel="recommended">
                <input type="checkbox" id="guidedPredictionAllowModelMismatch" name="allowModelMismatch">
                <label for="guidedPredictionAllowModelMismatch">Allow model mismatch</label>
              </div>
              <div class="form-group">
                <label for="guidedPredictionDbPath">Raw DB path</label>
                <input type="text" id="guidedPredictionDbPath" name="dbPath" placeholder="data/database/afl_predictions.db">
              </div>
              <div class="form-group">
                <label for="guidedPredictionOutputDir">Raw output directory</label>
                <input type="text" id="guidedPredictionOutputDir" name="outputDir" placeholder="data/predictions/win">
              </div>
              <div class="form-group" data-guided-prediction-mode-panel="recommended">
                <label for="guidedPredictionMethodOverride">Method override</label>
                <input type="text" id="guidedPredictionMethodOverride" name="methodOverride" placeholder="simple, linear, or diminishing_returns">
              </div>
            </div>
          </details>

          <button type="submit" class="button primary-button">Run prediction workflow</button>
        </form>
      </section>

      <section id="trainingWorkflow" class="workflow-panel is-hidden" data-workflow-panel>
        <div class="workflow-panel-heading">
          <div>
            <h3>Train model</h3>
            <p>Run one stage at a time. Optimise parameters first, then train from the selected parameter artifact.</p>
          </div>
        </div>

        <div class="form-group workflow-mode-control">
          <label for="trainOptimizationTarget">Model family</label>
          <select id="trainOptimizationTarget">
            <option value="win">Win probability</option>
            <option value="margin">Margin</option>
          </select>
        </div>

        <div data-train-mode-panel="win">
          <div class="workflow-stage">
            <h4>Stage 1: train or tune win model</h4>
            <p>Default window is 1990 through the previous completed season.</p>
            <form class="script-run-form" data-script-key="win-train">
              <div class="workflow-form-grid">
                <div class="form-group">
                  <label for="winTrainStartYear">Start year</label>
                  <input type="number" id="winTrainStartYear" name="startYear" min="1990" placeholder="1990">
                </div>
                <div class="form-group">
                  <label for="winTrainEndYear">End year</label>
                  <input type="number" id="winTrainEndYear" name="endYear" min="1990">
                </div>
              </div>
              <details class="script-advanced">
                <summary>Advanced training controls</summary>
                <div class="workflow-form-grid">
                  <div class="form-group">
                    <label for="winTrainDbPath">DB path</label>
                    <input type="text" id="winTrainDbPath" name="dbPath" placeholder="data/database/afl_predictions.db">
                  </div>
                  <div class="form-group">
                    <label for="winTrainOutputDir">Output directory</label>
                    <input type="text" id="winTrainOutputDir" name="outputDir" placeholder="data/models/win">
                  </div>
                  <div class="form-group checkbox">
                    <input type="checkbox" id="winTrainNoTuneParameters" name="noTuneParameters">
                    <label for="winTrainNoTuneParameters">Train from selected params without tuning</label>
                  </div>
                  <div class="form-group">
                    <label for="winTrainParamsFile">Win params file</label>
                    <select id="winTrainParamsFile" name="paramsFile"></select>
                  </div>
                  <div class="form-group">
                    <label for="winTrainMarginParams">Margin methods file</label>
                    <select id="winTrainMarginParams" name="marginParams"></select>
                  </div>
                  <div class="form-group">
                    <label for="winTrainCvFolds">CV folds</label>
                    <input type="number" id="winTrainCvFolds" name="cvFolds" min="2" max="10" placeholder="3">
                  </div>
                  <div class="form-group">
                    <label for="winTrainMaxCombinations">Max combinations</label>
                    <input type="number" id="winTrainMaxCombinations" name="maxCombinations" min="1" max="5000" placeholder="500">
                  </div>
                </div>
              </details>
              <div class="workflow-review compact">
                <strong>Impact:</strong> writes a model artifact under <code>data/models/win</code>; it does not publish predictions.
              </div>
              <button type="submit" class="button primary-button">Run win training stage</button>
            </form>
          </div>

          <div class="workflow-stage">
            <h4>Stage 2: optimise margin methods</h4>
            <p>Use the trained win model from stage 1 when you want margin outputs from the win model path.</p>
            <form class="script-run-form" data-script-key="win-margin-methods-optimize">
              <div class="workflow-form-grid">
                <div class="form-group">
                  <label for="winMarginMethodsOptimizeEloParamsPath">Win model or params</label>
                  <select id="winMarginMethodsOptimizeEloParamsPath" name="eloParamsPath" required></select>
                </div>
                <div class="form-group">
                  <label for="winMarginMethodsOptimizeStartYear">Start year</label>
                  <input type="number" id="winMarginMethodsOptimizeStartYear" name="startYear" min="1990" placeholder="1990">
                </div>
                <div class="form-group">
                  <label for="winMarginMethodsOptimizeEndYear">End year</label>
                  <input type="number" id="winMarginMethodsOptimizeEndYear" name="endYear" min="1990">
                </div>
              </div>
              <details class="script-advanced">
                <summary>Advanced optimisation controls</summary>
                <div class="workflow-form-grid">
                  <div class="form-group">
                    <label for="winMarginMethodsOptimizeNCalls">N calls</label>
                    <input type="number" id="winMarginMethodsOptimizeNCalls" name="nCalls" min="1" max="5000" placeholder="100">
                  </div>
                  <div class="form-group">
                    <label for="winMarginMethodsOptimizeRandomSeed">Random seed</label>
                    <input type="number" id="winMarginMethodsOptimizeRandomSeed" name="randomSeed" placeholder="42">
                  </div>
                  <div class="form-group">
                    <label for="winMarginMethodsOptimizeDbPath">DB path</label>
                    <input type="text" id="winMarginMethodsOptimizeDbPath" name="dbPath" placeholder="data/database/afl_predictions.db">
                  </div>
                  <div class="form-group">
                    <label for="winMarginMethodsOptimizeOutputPath">Output path</label>
                    <input type="text" id="winMarginMethodsOptimizeOutputPath" name="outputPath" placeholder="data/models/win/optimal_margin_methods_trained_to_YYYY.json">
                  </div>
                </div>
              </details>
              <div class="workflow-review compact">
                <strong>Impact:</strong> writes a margin-method artifact under <code>data/models/win</code>; it does not publish predictions.
              </div>
              <button type="submit" class="button primary-button">Run margin-method optimisation</button>
            </form>
          </div>
        </div>

        <div data-train-mode-panel="margin">
          <div class="workflow-stage">
            <h4>Stage 1: optimise margin params</h4>
            <p>Use this before training a new margin model.</p>
            <form class="script-run-form" data-script-key="margin-optimize">
              <div class="workflow-form-grid">
                <div class="form-group">
                  <label for="marginOptimizeStartYear">Start year</label>
                  <input type="number" id="marginOptimizeStartYear" name="startYear" min="1990" placeholder="1990">
                </div>
                <div class="form-group">
                  <label for="marginOptimizeEndYear">End year</label>
                  <input type="number" id="marginOptimizeEndYear" name="endYear" min="1990">
                </div>
              </div>
              <details class="script-advanced">
                <summary>Advanced optimisation controls</summary>
                <div class="workflow-form-grid">
                  <div class="form-group">
                    <label for="marginOptimizeMaxCombinations">Max combinations</label>
                    <input type="number" id="marginOptimizeMaxCombinations" name="maxCombinations" min="1" max="5000" placeholder="500">
                  </div>
                  <div class="form-group">
                    <label for="marginOptimizeDbPath">DB path</label>
                    <input type="text" id="marginOptimizeDbPath" name="dbPath" placeholder="data/database/afl_predictions.db">
                  </div>
                  <div class="form-group">
                    <label for="marginOptimizeOutputPath">Output path</label>
                    <input type="text" id="marginOptimizeOutputPath" name="outputPath" placeholder="data/models/margin/optimal_margin_only_elo_params_trained_to_YYYY.json">
                  </div>
                </div>
              </details>
              <div class="workflow-review compact">
                <strong>Impact:</strong> writes a params artifact under <code>data/models/margin</code>.
              </div>
              <button type="submit" class="button primary-button">Run margin params optimisation</button>
            </form>
          </div>

          <div class="workflow-stage">
            <h4>Stage 2: train margin model</h4>
            <p>Select the params artifact from stage 1, then train the model artifact.</p>
            <form class="script-run-form" data-script-key="margin-train">
              <div class="workflow-form-grid">
                <div class="form-group">
                  <label for="marginTrainParamsFile">Params file</label>
                  <select id="marginTrainParamsFile" name="paramsFile" required></select>
                </div>
                <div class="form-group">
                  <label for="marginTrainStartYear">Start year</label>
                  <input type="number" id="marginTrainStartYear" name="startYear" min="1990" placeholder="1990">
                </div>
                <div class="form-group">
                  <label for="marginTrainEndYear">End year</label>
                  <input type="number" id="marginTrainEndYear" name="endYear" min="1990">
                </div>
              </div>
              <details class="script-advanced">
                <summary>Advanced training controls</summary>
                <div class="workflow-form-grid">
                  <div class="form-group">
                    <label for="marginTrainDbPath">DB path</label>
                    <input type="text" id="marginTrainDbPath" name="dbPath" placeholder="data/database/afl_predictions.db">
                  </div>
                  <div class="form-group">
                    <label for="marginTrainOutputDir">Output directory</label>
                    <input type="text" id="marginTrainOutputDir" name="outputDir" placeholder="data/models/margin">
                  </div>
                </div>
              </details>
              <div class="workflow-review compact">
                <strong>Impact:</strong> writes a trained margin model under <code>data/models/margin</code>; it does not publish predictions.
              </div>
              <button type="submit" class="button primary-button">Run margin training stage</button>
            </form>
          </div>
        </div>
      </section>

      <section id="simulationWorkflow" class="workflow-panel is-hidden" data-workflow-panel>
        <div class="workflow-panel-heading">
          <div>
            <h3>Run simulation</h3>
            <p>Run Monte Carlo season projections from the selected model and write the standard simulation JSON output.</p>
          </div>
        </div>

        <form class="script-run-form" data-script-key="season-simulation">
          <div class="workflow-form-grid">
            <div class="form-group">
              <label for="simYear">Season</label>
              <input type="number" id="simYear" name="year" min="1990" required>
            </div>
            <div class="form-group">
              <label for="simModelPath">Margin model</label>
              <select id="simModelPath" name="modelPath" required></select>
            </div>
            <div class="form-group">
              <label for="simWinModelPath">Win model</label>
              <select id="simWinModelPath" name="winModelPath"></select>
            </div>
          </div>
          <details class="script-advanced danger-zone">
            <summary>Dangerous options</summary>
            <div class="workflow-form-grid">
              <div class="form-group">
                <label for="simDbPath">DB path</label>
                <input type="text" id="simDbPath" name="dbPath" placeholder="data/database/afl_predictions.db">
              </div>
              <div class="form-group">
                <label for="simNumSimulations">Simulations</label>
                <input type="number" id="simNumSimulations" name="numSimulations" min="1000" max="200000" placeholder="50000">
              </div>
              <div class="form-group checkbox">
                <input type="checkbox" id="simFromScratch" name="fromScratch">
                <label for="simFromScratch">Ignore current-season hard constraints</label>
              </div>
              <div class="form-group checkbox">
                <input type="checkbox" id="simBackfillRoundSnapshots" name="backfillRoundSnapshots">
                <label for="simBackfillRoundSnapshots">Rebuild round snapshots</label>
              </div>
              <div class="form-group">
                <label for="simOutput">Output file</label>
                <input type="text" id="simOutput" name="output" placeholder="data/simulations/season_simulation_YYYY.json">
              </div>
            </div>
          </details>
          <div class="workflow-review compact">
            <strong>Impact:</strong> writes <code>data/simulations/season_simulation_YYYY.json</code> unless the output path is changed.
          </div>
          <button type="submit" class="button primary-button">Run season simulation</button>
        </form>
      </section>

      <section id="historyWorkflow" class="workflow-panel is-hidden" data-workflow-panel>
        <div class="workflow-panel-heading">
          <div>
            <h3>Update ELO history</h3>
            <p>Use incremental mode for normal updates. Full rebuild is available when the historical seed window needs to be regenerated.</p>
          </div>
        </div>

        <form class="script-run-form" data-script-key="elo-history">
          <div class="workflow-form-grid">
            <div class="form-group">
              <label for="historyModelPath">Model</label>
              <select id="historyModelPath" name="modelPath" required></select>
            </div>
            <div class="form-group">
              <label for="historyMode">Mode</label>
              <select id="historyMode" name="mode">
                <option value="incremental">Incremental</option>
                <option value="full">Full rebuild</option>
              </select>
            </div>
          </div>
          <details class="script-advanced danger-zone">
            <summary>Dangerous options</summary>
            <div class="workflow-form-grid">
              <div class="form-group">
                <label for="historySeedStartYear">Seed start year</label>
                <input type="number" id="historySeedStartYear" name="seedStartYear" min="1990">
              </div>
              <div class="form-group">
                <label for="historySeedEndYear">Seed end year</label>
                <input type="number" id="historySeedEndYear" name="seedEndYear" min="1990">
              </div>
              <div class="form-group">
                <label for="historyOutputStartYear">Output start year</label>
                <input type="number" id="historyOutputStartYear" name="outputStartYear" min="1990">
              </div>
              <div class="form-group">
                <label for="historyOutputEndYear">Output end year</label>
                <input type="number" id="historyOutputEndYear" name="outputEndYear" min="1990">
              </div>
              <div class="form-group">
                <label for="historyDbPath">DB path</label>
                <input type="text" id="historyDbPath" name="dbPath" placeholder="data/database/afl_predictions.db">
              </div>
              <div class="form-group">
                <label for="historyOutputDir">Output directory</label>
                <input type="text" id="historyOutputDir" name="outputDir" placeholder="data/historical">
              </div>
              <div class="form-group">
                <label for="historyOutputPrefix">Output prefix</label>
                <input type="text" id="historyOutputPrefix" name="outputPrefix" placeholder="afl_elo_complete_history">
              </div>
            </div>
          </details>
          <div class="workflow-review compact">
            <strong>Impact:</strong> updates historical CSV output under <code>data/historical</code>.
          </div>
          <button type="submit" class="button primary-button">Run ELO history update</button>
        </form>
      </section>
    </div>

    <div class="admin-section">
      <h2>Run History</h2>
      <div class="history-table-wrapper">
        <table class="admin-table" id="scriptRunHistoryTable">
          <thead>
            <tr>
              <th>ID</th>
              <th>Script</th>
              <th>Status</th>
              <th>Started</th>
              <th>Finished</th>
              <th>By</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody id="scriptRunHistoryBody">
            <tr>
              <td colspan="7">Loading history...</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <div class="admin-section">
      <h2>Run Logs</h2>
      <p id="logRunLabel">Select a run from history to view logs.</p>
      <pre id="scriptLogsOutput" class="script-logs-output">No logs loaded.</pre>
    </div>
  </div>
</div>

<script src="<%= assetPath('/js/main.js') %>"></script>
<script src="<%= assetPath('/js/admin-scripts.js') %>"></script>

<%- include('partials/footer') %>
