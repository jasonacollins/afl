<%- include('partials/header') %>

<div class="container">
  <div class="tab-navigation">
    <a href="/admin" class="tab active">Predictor Management</a>
    <a href="/admin/user-predictions" class="tab">Manage User Predictions</a>
    <a href="/admin/scripts" class="tab">Scripts</a>
    <a href="/admin/operations" class="tab">Operations</a>
  </div>
  
  <% if (locals.success) { %>
    <div class="alert success">
      <%= success %>
    </div>
  <% } %>
  
  <% if (locals.error) { %>
    <div class="alert error">
      <%= error %>
    </div>
  <% } %>
  
  <div class="admin-section">
    <h2>Featured Predictor</h2>
    <p>Select the single predictor to feature on the homepage:</p>
    <form action="/admin/set-featured-predictors" method="POST" class="admin-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="form-group">
        <div class="checkbox-group">
          <% predictors.forEach(predictor => { %>
            <div class="checkbox-item">
              <input 
                type="radio" 
                id="predictor_<%= predictor.predictor_id %>" 
                name="predictorId" 
                value="<%= predictor.predictor_id %>"
                <%= predictor.active === 0 ? 'disabled' : 'required' %>
                <%= featuredPredictorId && featuredPredictorId.toString() === predictor.predictor_id.toString() ? 'checked' : '' %>
              >
              <label for="predictor_<%= predictor.predictor_id %>">
                <%= predictor.display_name %><%= predictor.active === 0 ? ' (Inactive)' : '' %>
              </label>
            </div>
          <% }) %>
        </div>
      </div>
      <button type="submit" class="button primary-button">Save Settings</button>
    </form>
  </div>

  <div class="admin-container">
    <div class="admin-section">
      <h2>Add New Predictor</h2>
      <form action="/admin/predictors" method="POST" class="admin-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="form-group">
          <label for="username">Username</label>
          <input type="text" id="username" name="username" required>
        </div>
        
        <div class="form-group">
          <label for="displayName">Display Name</label>
          <input type="text" id="displayName" name="displayName" required>
        </div>

        <div class="form-group">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" required>
        </div>
        
        <div class="form-group checkbox">
          <input type="checkbox" id="isAdmin" name="isAdmin">
          <label for="isAdmin">Admin privileges</label>
        </div>
        
        <div class="form-group">
          <label for="yearJoined">Year Joined</label>
          <input type="number" id="yearJoined" name="yearJoined" 
                 min="2020" max="<%= new Date().getFullYear() %>" 
                 value="<%= new Date().getFullYear() %>" required>
        </div>
        
        <button type="submit" class="button primary-button">Add Predictor</button>
      </form>
    </div>
    
    <div class="admin-section">
      <h2>Current Predictors</h2>
      <table class="admin-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Username</th>
            <th>Display Name</th>
            <th>Role</th>
            <th>Year Joined</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% predictors.forEach(predictor => { %>
            <tr class="<%= predictor.active === 0 ? 'inactive-predictor' : '' %>">
              <td><%= predictor.predictor_id %></td>
              <td><%= predictor.name %></td>
              <td><%= predictor.display_name %></td>
              <td><%= predictor.is_admin ? 'Admin' : 'User' %></td>
              <td><%= predictor.year_joined || 'N/A' %></td>
              <td>
                <button
                  data-action="toggle-active-status"
                  data-predictor-id="<%= predictor.predictor_id %>"
                  data-active="<%= predictor.active !== 0 %>"
                  class="button <%= predictor.active === 0 ? 'secondary-button' : 'primary-button' %>"
                >
                  <%= predictor.active === 0 ? 'Inactive' : 'Active' %>
                </button>
              </td>
              <td>
                <button
                  data-action="show-reset-password"
                  data-user-id="<%= predictor.predictor_id %>"
                  data-user-name="<%= predictor.display_name %>"
                  class="button secondary-button"
                >
                  Reset Password
                </button>
                <button
                  data-action="confirm-delete-user"
                  data-user-id="<%= predictor.predictor_id %>"
                  data-user-name="<%= predictor.display_name %>"
                  class="button secondary-button delete-button"
                >
                  Delete User
                </button>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Add a hidden modal for password reset -->
<div id="resetPasswordModal" class="modal is-hidden">
  <div class="modal-content">
    <span class="close" data-action="close-modal">&times;</span>
    <h3>Reset Password for <span id="resetUserName"></span></h3>
    <form id="resetPasswordForm" action="/admin/reset-password/0" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="form-group">
        <label for="newPassword">New Password</label>
        <input type="password" id="newPassword" name="newPassword" required>
      </div>
      <button type="submit" class="button primary-button">Reset Password</button>
    </form>
  </div>
</div>

<!-- Add a hidden modal for delete confirmation -->
<div id="deleteUserModal" class="modal is-hidden">
  <div class="modal-content">
    <span class="close" data-action="close-delete-modal">&times;</span>
    <h3>Delete User: <span id="deleteUserName"></span></h3>
    <p>Are you sure you want to delete this user? This action cannot be undone.</p>
    <p>All predictions made by this user will also be deleted.</p>
    <form id="deleteUserForm" action="/admin/delete-user/0" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="form-actions">
        <button type="button" class="button secondary-button" data-action="close-delete-modal">Cancel</button>
        <button type="submit" class="button primary-button delete-button">Delete User</button>
      </div>
    </form>
  </div>
</div>

<script src="/js/admin.js"></script>

<%- include('partials/footer') %>
